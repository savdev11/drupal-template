# Project identity
COMPOSE_PROJECT_NAME=drupal_template
APP_NAME=drupal-template
APP_ENV=local
APP_BASE_URL=http://localhost:8080

# Domains / security
TRUSTED_HOST_PATTERNS=^localhost$,^127\.0\.0\.1$
DRUPAL_HASH_SALT=change-me-in-real-environments
DRUPAL_ADMIN_USER=admin
DRUPAL_ADMIN_PASS=admin
DRUPAL_SITE_NAME=Drupal Template

# Database
DB_NAME=drupal
DB_USER=drupal
DB_PASSWORD=drupal
DB_ROOT_PASSWORD=drupal_root
DB_HOST=db
DB_PORT=3306
DB_DRIVER=mysql

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Filesystem
DRUPAL_FILES_PUBLIC_PATH=sites/default/files
DRUPAL_FILES_PRIVATE_PATH=/var/www/private
DRUPAL_FILES_TEMP_PATH=/tmp

# Reverse proxy / varnish
REVERSE_PROXY=true
VARNISH_PURGER_HOST=varnish
VARNISH_PURGER_PORT=80

# Local developer UX
XDEBUG_MODE=off
XDEBUG_CLIENT_HOST=host.docker.internal
XDEBUG_CLIENT_PORT=9003
PHP_MEMORY_LIMIT=512M
PHP_MAX_EXECUTION_TIME=120

# Mail (local default)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_PROTOCOL=

# Ports (local)
VARNISH_PORT=8080
NGINX_PORT=8081
MAILPIT_SMTP_PORT=1025
MAILPIT_HTTP_PORT=8025
DB_EXPOSE_PORT=33060
REDIS_EXPOSE_PORT=63790

# Stage file proxy origin for local/stage
STAGE_FILE_PROXY_ORIGIN=https://example.com

# Optional remote sync settings
REMOTE_SSH_HOST=
REMOTE_SSH_USER=
REMOTE_PROJECT_PATH=
REMOTE_FILES_PATH=
