<?xml version="1.0"?>
<ruleset name="Drupal Platform Template"
  xmlns="http://pmd.sf.net/ruleset/1.0.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://pmd.sf.net/ruleset/1.0.0 https://pmd.github.io/pmd-6.55.0/ruleset_xml_schema.xsd"
  xsi:noNamespaceSchemaLocation="https://pmd.github.io/pmd-6.55.0/ruleset_xml_schema.xsd">
  <description>PHPMD rules for custom Drupal code.</description>
  <rule ref="rulesets/cleancode.xml" />
  <rule ref="rulesets/codesize.xml" />
  <rule ref="rulesets/design.xml" />
  <rule ref="rulesets/naming.xml" />
  <rule ref="rulesets/unusedcode.xml" />
  <exclude-pattern>*/tests/*</exclude-pattern>
</ruleset>
